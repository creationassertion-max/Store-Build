# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lumiere?sslmode=require

# Stripe API keys (use test mode keys for development)
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret (for local testing use: stripe listen --forward-to localhost:3000/api/webhooks/stripe)
# Get from: https://dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Your deployed URL (update after Vercel deployment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
